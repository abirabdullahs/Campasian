<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.campasian.controller.FriendListController"
      styleClass="friends-root"
      spacing="0" maxWidth="Infinity" maxHeight="Infinity">

    <!-- Top Bar -->
    <HBox styleClass="friends-topbar" alignment="CENTER_LEFT" spacing="12">
        <Label text="👥" styleClass="friends-topbar-icon"/>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Friends" styleClass="friends-topbar-title"/>
            <Label text="Your friends list" styleClass="friends-topbar-sub"/>
        </VBox>
    </HBox>

    <Separator styleClass="friends-divider"/>

    <!-- Search Bar -->
    <VBox styleClass="friends-search-wrap" spacing="0">
        <TextField promptText="Search friends..."
                   styleClass="friends-search-field"
                   maxWidth="Infinity"/>
    </VBox>

    <Separator styleClass="friends-divider"/>

    <!-- Friends List -->
    <ScrollPane fitToWidth="true"
                styleClass="friends-scroll"
                VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED">
        <VBox fx:id="friendsVBox" spacing="8" styleClass="friends-list-container">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
        </VBox>
    </ScrollPane>

</VBox>
