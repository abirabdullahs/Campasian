<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.campasian.controller.ResourceController"
      styleClass="resource-root"
      stylesheets="@../styles/app.css,@../styles/resource.css"
      spacing="20"
      maxWidth="Infinity" maxHeight="Infinity">
    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox styleClass="page-header" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Course Resource Library" styleClass="page-title"/>
            <Label text="Browse organized course materials, filter by department and semester, and open shared resources in one place." styleClass="page-subtitle" wrapText="true"/>
        </VBox>

        <Button fx:id="addBtn"
                text="+ Add Resource"
                styleClass="resource-add-btn"
                onAction="#onAddClick"/>
    </HBox>

    <VBox styleClass="resource-toolbar" spacing="16">
        <VBox spacing="10">
            <Label text="Department" styleClass="resource-filter-label"/>
            <FlowPane hgap="10" vgap="10" prefWrapLength="760">
                <Button fx:id="allDeptBtn" text="All" styleClass="resource-filter-btn resource-filter-btn-active" onAction="#onFilterAllDept"/>
                <Button fx:id="cseDeptBtn" text="CSE" styleClass="resource-filter-btn" onAction="#onFilterCSE"/>
                <Button fx:id="eeeDeptBtn" text="EEE" styleClass="resource-filter-btn" onAction="#onFilterEEE"/>
                <Button fx:id="bbaDeptBtn" text="BBA" styleClass="resource-filter-btn" onAction="#onFilterBBA"/>
            </FlowPane>
        </VBox>

        <VBox spacing="10">
            <Label text="Semester" styleClass="resource-filter-label"/>
            <FlowPane hgap="10" vgap="10" prefWrapLength="760">
                <Button fx:id="allSemBtn" text="All" styleClass="resource-filter-btn resource-filter-btn-active" onAction="#onFilterAllSem"/>
                <Button fx:id="sem1Btn" text="Sem 1" styleClass="resource-filter-btn" onAction="#onFilterSem1"/>
                <Button fx:id="sem2Btn" text="Sem 2" styleClass="resource-filter-btn" onAction="#onFilterSem2"/>
                <Button fx:id="sem3Btn" text="Sem 3" styleClass="resource-filter-btn" onAction="#onFilterSem3"/>
            </FlowPane>
        </VBox>
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="resource-scroll" VBox.vgrow="ALWAYS">
        <VBox fx:id="itemsVBox" spacing="18" styleClass="resource-list"/>
    </ScrollPane>
</VBox>
