<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.campasian.controller.BloodSearchController"
      styleClass="blood-search-root"
      stylesheets="@../styles/app.css,@../styles/blood-search.css"
      maxWidth="Infinity" maxHeight="Infinity">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- Header -->
    <VBox styleClass="page-header" spacing="4">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="🩸" styleClass="blood-search-icon"/>
            <Label text="Blood Donation Hub" styleClass="page-title"/>
        </HBox>
        <Label text="Select your blood group to find and request blood donors." styleClass="page-subtitle" wrapText="true"/>
    </VBox>

    <!-- Blood Group Selection -->
    <VBox spacing="12" styleClass="blood-group-section">
        <Label text="Select Blood Group" styleClass="profile-label"/>
        <HBox fx:id="bloodGroupPanel" spacing="8" styleClass="blood-group-buttons" style="-fx-wrap-text: true;"/>
    </VBox>

    <!-- Donors List -->
    <ScrollPane fitToWidth="true" styleClass="feed-scroll" VBox.vgrow="ALWAYS" style="-fx-padding: 16 0 0 0;">
        <VBox fx:id="donorsVBox" spacing="12" styleClass="feed-container"/>
    </ScrollPane>
</VBox>