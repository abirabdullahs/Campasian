<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="communityRoot"
            prefHeight="760.0"
            prefWidth="1200.0"
            styleClass="dashboard-main community-root"
            stylesheets="@../styles/app.css,@../styles/community.css"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="com.campasian.controller.CommunityController">

    <center>
        <SplitPane fx:id="communitySplitPane" dividerPositions="0.24" styleClass="community-split-pane">
            <items>
                <VBox prefWidth="320.0" styleClass="community-sidebar">
                    <padding>
                        <Insets top="24" right="18" bottom="24" left="24"/>
                    </padding>
                    <children>
                        <VBox spacing="6">
                            <Label text="Communities" styleClass="community-sidebar-title"/>
                            <Label text="Verified student rooms, department spaces, and custom communities." styleClass="community-sidebar-subtitle" wrapText="true"/>
                        </VBox>

                        <VBox spacing="8" styleClass="community-sidebar-card">
                            <Label text="Campus Rooms" styleClass="community-sidebar-card-title"/>
                            <Label text="Rooms update automatically and open the latest discussion without reloading the page." styleClass="community-sidebar-card-body" wrapText="true"/>
                        </VBox>

                        <Button fx:id="createRoomButton"
                                text="➕ Create New Room"
                                styleClass="community-send-btn"
                                onAction="#onCreateRoomClick"
                                maxWidth="Infinity"/>

                        <ListView fx:id="communityListView"
                                  VBox.vgrow="ALWAYS"
                                  styleClass="community-room-list"/>
                    </children>
                </VBox>

                <VBox spacing="16" styleClass="community-main">
                    <padding>
                        <Insets top="24" right="16" bottom="24" left="18"/>
                    </padding>
                    <children>
                        <VBox spacing="12" styleClass="community-header">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label fx:id="titleLabel" text="Community" styleClass="community-title"/>
                                    <Label fx:id="subtitleLabel" text="Pick a room to start reading and writing messages." styleClass="community-subtitle" wrapText="true"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label fx:id="verificationLabel" text="Verification unavailable" styleClass="community-pill"/>
                                <Label fx:id="memberCountLabel" text="0 students" styleClass="community-pill community-pill-secondary"/>
                            </HBox>
                        </VBox>

                        <ListView fx:id="messageListView"
                                  VBox.vgrow="ALWAYS"
                                  styleClass="community-message-list"/>

                        <VBox spacing="10" styleClass="community-composer-card">
                            <Label fx:id="communityHintLabel"
                                   text="Choose a room and join the conversation."
                                   styleClass="community-hint"
                                   wrapText="true"/>
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <TextField fx:id="messageField"
                                           promptText="Write a message..."
                                           styleClass="community-input"
                                           HBox.hgrow="ALWAYS"/>
                                <Button fx:id="attachImageBtn"
                                        text="📎"
                                        styleClass="community-attach-btn"
                                        onAction="#onAttachImageClick"/>
                                <Button fx:id="sendButton"
                                        onAction="#onSendClick"
                                        styleClass="community-send-btn"
                                        text="Send"/>
                            </HBox>
                        </VBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>