<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="communityRoot" prefHeight="760.0" prefWidth="1200.0" styleClass="dashboard-main community-root" stylesheets="@../styles/app.css,@../styles/community.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.campasian.controller.CommunityController">

    <left>
        <VBox prefWidth="320.0" styleClass="community-sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="24.0" left="24.0" right="20.0" top="24.0" />
            </padding>
            <children>
                <Label styleClass="community-sidebar-title" text="Communities" />
                <Label styleClass="community-sidebar-subtitle" text="Verified student rooms built from university identity and department membership." wrapText="true" />
                <VBox spacing="6" styleClass="community-sidebar-card">
                    <Label styleClass="community-sidebar-card-title" text="Campus Rooms" />
                    <Label styleClass="community-sidebar-card-body" text="Auto-joined general rooms, department lounges, and your own custom communities live here." wrapText="true" />
                </VBox>
                <ListView fx:id="communityListView" styleClass="community-room-list" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </left>

    <center>
        <SplitPane fx:id="communitySplitPane" dividerPositions="0.5" styleClass="community-split-pane">
            <items>
                <VBox spacing="18.0" styleClass="community-main">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="16.0" top="24.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12" />

                        <Separator />

                        <VBox spacing="10.0" styleClass="community-composer-card">
                            <Label fx:id="communityHintLabel" styleClass="community-hint" text="Auto-join is triggered from signup; use ObservableList to refresh the room instantly." wrapText="true" />
                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                <TextField fx:id="messageField" promptText="Write to your university community..." styleClass="community-input" HBox.hgrow="ALWAYS" />
                                <Button fx:id="sendButton" onAction="#onSendClick" styleClass="community-send-btn" text="Send" />
                            </HBox>
                        </VBox>
                    </children>
                </VBox>

                <VBox fx:id="communityRightPanel" spacing="16.0" styleClass="community-right-panel">
                    <padding>
                        <Insets bottom="24.0" left="16.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <VBox spacing="10" styleClass="community-editor-card">
                            <Label fx:id="communityEditorLabel" styleClass="community-editor-title" text="Create a new custom community" />
                            <Label styleClass="community-editor-subtitle" text="Build department clubs, project rooms, or student-led discussion spaces." wrapText="true" />
                            <TextField fx:id="communityNameField" promptText="Community name" styleClass="community-input" />
                            <TextArea fx:id="communityDescriptionField" prefRowCount="4" promptText="Short description" styleClass="community-textarea" wrapText="true" />
                            <HBox spacing="8">
                                <Button fx:id="createCommunityButton" onAction="#onCreateCommunityClick" styleClass="community-send-btn" text="Create" />
                                <Button fx:id="saveCommunityButton" onAction="#onSaveCommunityClick" styleClass="community-secondary-btn" text="Save" />
                                <Button fx:id="deleteCommunityButton" onAction="#onDeleteCommunityClick" styleClass="community-danger-btn" text="Delete" />
                            </HBox>
                        </VBox>

                        <VBox spacing="8" styleClass="community-editor-card">
                            <Label styleClass="community-editor-title" text="Panel controls" />
                            <Label styleClass="community-editor-subtitle" text="Drag the divider to resize this panel. Use Hide Panel to collapse it and Show Panel to bring it back." wrapText="true" />
                        </VBox>

                        <VBox spacing="8" styleClass="community-editor-card community-accent-card">
                            <Label styleClass="community-editor-title" text="Live sync" />
                            <Label styleClass="community-editor-subtitle" text="Community rooms and messages refresh automatically, so new messages from other students appear without reloading the page." wrapText="true" />
                        </VBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
