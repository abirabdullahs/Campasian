<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.campasian.controller.MarketplaceController"
      styleClass="marketplace-root"
      stylesheets="@../styles/marketplace.css"
      maxWidth="Infinity" maxHeight="Infinity">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox styleClass="marketplace-hero" spacing="18" alignment="CENTER_LEFT">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Campus Marketplace" styleClass="marketplace-title"/>
            <Label text="Student-to-student listings for books, electronics, and everyday campus gear." styleClass="marketplace-subtitle" wrapText="true"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label fx:id="resultsLabel" text="0 items live" styleClass="marketplace-stat-chip"/>
                <Label fx:id="spotlightLabel" text="Latest drop: waiting for new listings" styleClass="marketplace-stat-chip marketplace-stat-chip-muted"/>
            </HBox>
        </VBox>
        <Button fx:id="sellBtn" text="+ Sell Item" styleClass="marketplace-sell-btn" onAction="#onSellItemClick"/>
    </HBox>

    <VBox styleClass="marketplace-toolbar" spacing="14">
        <TextField fx:id="searchField" promptText="Search by title or description..." styleClass="marketplace-search" prefWidth="320"/>

        <FlowPane hgap="8" vgap="8">
            <Button fx:id="allBtn" text="All Listings" styleClass="marketplace-filter-btn marketplace-filter-btn-active" onAction="#onFilterAll"/>
            <Button fx:id="booksBtn" text="Books" styleClass="marketplace-filter-btn" onAction="#onFilterBooks"/>
            <Button fx:id="electronicsBtn" text="Electronics" styleClass="marketplace-filter-btn" onAction="#onFilterElectronics"/>
            <Button fx:id="stationeryBtn" text="Stationery" styleClass="marketplace-filter-btn" onAction="#onFilterStationery"/>
        </FlowPane>
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="marketplace-scroll" VBox.vgrow="ALWAYS">
        <VBox fx:id="itemsVBox" spacing="14" styleClass="marketplace-feed">
            <padding>
                <Insets top="8" right="0" bottom="12" left="0"/>
            </padding>
        </VBox>
    </ScrollPane>
</VBox>
